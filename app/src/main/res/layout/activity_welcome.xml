<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#08080F"
    android:fillViewport="true">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">
        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="Y"
            android:textSize="36sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/logo_bg"
            android:layout_marginBottom="12dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yrener"
            android:textSize="26sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="МЕНЮ НОВОГО ПОКОЛЕНИЯ"
            android:textSize="11sp"
            android:textColor="#888899"
            android:layout_marginBottom="40dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card"
            android:padding="24dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Добро пожаловать"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Войди или зарегистрируйся"
                android:textSize="13sp"
                android:textColor="#888899"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>
            <Button
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Зарегистрироваться"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_primary"
                android:layout_marginBottom="12dp"/>
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Войти в аккаунт"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_glass"
                android:layout_marginBottom="12dp"/>
            <Button
                android:id="@+id/btn_tg"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Telegram канал"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_tg"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
