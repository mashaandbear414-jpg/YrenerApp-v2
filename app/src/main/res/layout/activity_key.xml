<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#08080F"
    android:padding="28dp">

    <TextView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="Y"
        android:textSize="36sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/logo_bg"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Активация"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Введи ключ для доступа"
        android:textSize="13sp"
        android:textColor="#888899"
        android:layout_marginBottom="28dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/glass_card"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ключ доступа"
            android:textSize="13sp"
            android:textColor="#888899"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/et_key"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Например: AB1.CD"
            android:textColor="#FFFFFF"
            android:textColorHint="#555566"
            android:textSize="18sp"
            android:padding="16dp"
            android:background="@drawable/input_bg"
            android:inputType="text"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#6C63FF"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_activate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Активировать ключ"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:layout_marginBottom="12dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_get_key"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Получить ключ в боте"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/btn_tg"/>

        <TextView
            android:id="@+id/tv_redirect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="После нажатия откроется бот"
            android:textSize="12sp"
            android:textColor="#555566"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</LinearLayout>
