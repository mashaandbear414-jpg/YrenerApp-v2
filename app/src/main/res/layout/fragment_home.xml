<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#08080F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="Y"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/logo_bg"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yrener"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_user_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="13sp"
                android:textColor="#888899"/>

        </LinearLayout>

        <!-- Key status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔑 Активный ключ"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_key_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Активен"
                    android:textSize="12sp"
                    android:textColor="#34D399"
                    android:background="#1534D399"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textSize="28sp"
                android:textColor="#34D399"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="monospace"
                android:background="#0834D399"
                android:padding="12dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_key_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#888899"
                android:gravity="center"
                android:fontFamily="monospace"/>

        </LinearLayout>

        <!-- Launch button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎮 Black Russia"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Запусти игру с активным меню"
                android:textSize="13sp"
                android:textColor="#888899"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btn_launch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="💉 Запустить с меню"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_inject_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Требуется VMOS Pro с root"
                android:textSize="12sp"
                android:textColor="#888899"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Quick actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="БЫСТРЫЕ ДЕЙСТВИЯ"
            android:textSize="11sp"
            android:textColor="#888899"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btn_tg_channel"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/glass_card"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✈️" android:textSize="24sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TG Канал" android:textSize="12sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_get_key"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/glass_card"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤖" android:textSize="24sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Получить ключ" android:textSize="12sp" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yrener Menu v1.4 · Black Russia"
            android:textSize="11sp"
            android:textColor="#555566"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
