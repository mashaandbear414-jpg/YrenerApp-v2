<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#08080F"
    android:padding="28dp">

    <TextView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:text="Y"
        android:textSize="36sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/logo_bg"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/glass_card"
        android:padding="28dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌐"
            android:textSize="44sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Регистрация через сайт"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Вы будете перенаправлены на сайт Yrener. После регистрации вернитесь и войдите в приложение."
            android:textSize="13sp"
            android:textColor="#888899"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tv_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5"
            android:textSize="36sp"
            android:textColor="#A78BFA"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="секунд до перехода"
            android:textSize="13sp"
            android:textColor="#555566"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_open_site"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Открыть сайт сейчас"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/btn_primary"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="← Назад"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/btn_glass"/>

    </LinearLayout>
</LinearLayout>
