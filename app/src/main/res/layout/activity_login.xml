<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#08080F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="Y"
            android:textSize="36sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/logo_bg"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Войти"
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="28dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textSize="13sp"
                android:textColor="#888899"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="your@email.com"
                android:textColor="#FFFFFF"
                android:textColorHint="#555566"
                android:textSize="15sp"
                android:padding="16dp"
                android:background="@drawable/input_bg"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пароль"
                android:textSize="13sp"
                android:textColor="#888899"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="••••••••"
                android:textColor="#FFFFFF"
                android:textColorHint="#555566"
                android:textSize="15sp"
                android:padding="16dp"
                android:background="@drawable/input_bg"
                android:inputType="textPassword"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_forgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Забыли пароль?"
                android:textSize="13sp"
                android:textColor="#A78BFA"
                android:layout_gravity="end"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#6C63FF"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Войти"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_primary"
                android:layout_marginBottom="12dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#20FFFFFF"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_google"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Войти через Google"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="@drawable/btn_glass"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Нет аккаунта? Зарегистрироваться"
            android:textSize="14sp"
            android:textColor="#A78BFA"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"/>

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="← Назад"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/btn_glass"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>
